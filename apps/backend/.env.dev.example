# Orbit backend - development environment variables
APP_ENV=development
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=dev-change-me
JWT_SECRET_KEY=dev-change-me
DATABASE_URL=postgresql+psycopg2://orbit:orbit@localhost:5432/orbit_dev
SQLALCHEMY_DATABASE_URI=${DATABASE_URL}
SQLALCHEMY_TRACK_MODIFICATIONS=False
LOG_LEVEL=DEBUG
MAIL_SERVER=localhost
MAIL_PORT=1025
MAIL_USE_TLS=False
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=orbit-dev@example.com
CORS_ORIGINS=http://localhost:3000
AUTH_NETMIKO_HOST=127.0.0.1
AUTH_NETMIKO_DEVICE_TYPE=cisco_ios
AUTH_NETMIKO_PORT=22
AUTH_NETMIKO_TIMEOUT=10
AUTH_LOGIN_MAX_ATTEMPTS=5
AUTH_LOGIN_WINDOW_SECONDS=900
AUTH_LOGIN_LOCKOUT_SECONDS=900
