# apps/backend/.env.dev.example
# -----------------------------
# Development environment variables for Orbit backend

APP_ENV=development
FLASK_ENV=development

# SQLite for local dev (file-based for persistence, memory-only also fine)
DATABASE_URL=sqlite:///dev.db

# JWT secret (dev only)
JWT_SECRET_KEY=dev-secret-key

# SMTP settings (optional for dev; will log to stdout if misconfigured)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=false
SMTP_STARTTLS=false
MAIL_FROM=orbit-dev@local
MAIL_TO_CRITICAL=orbit-critical-dev@local