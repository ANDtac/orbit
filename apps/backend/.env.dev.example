# Orbit backend - development environment variables
APP_ENV=development
FLASK_ENV=development

FLASK_DEBUG=1
SECRET_KEY=dev-change-me
JWT_SECRET_KEY=dev-change-me
DATABASE_URL=postgresql+psycopg2://orbit:orbit@localhost:5432/orbit_dev
SQLALCHEMY_DATABASE_URI=${DATABASE_URL}
SQLALCHEMY_TRACK_MODIFICATIONS=False
LOG_LEVEL=DEBUG
MAIL_SERVER=localhost
MAIL_PORT=1025
MAIL_USE_TLS=False
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=orbit-dev@example.com
CORS_ORIGINS=http://localhost:3000
AUTH_NETMIKO_HOST=127.0.0.1
AUTH_NETMIKO_DEVICE_TYPE=cisco_ios
AUTH_NETMIKO_PORT=22
AUTH_NETMIKO_TIMEOUT=10
AUTH_LOGIN_MAX_ATTEMPTS=5
AUTH_LOGIN_WINDOW_SECONDS=900
AUTH_LOGIN_LOCKOUT_SECONDS=900

# SQLite for local dev (file-based for persistence, memory-only also fine)
DATABASE_URL=sqlite:///dev.db

# JWT secret (dev only)
JWT_SECRET_KEY=dev-secret-key

# SMTP settings (optional for dev; only host required for simple relays)
SMTP_HOST=localhost
# Uncomment to override defaults (port 25 / no auth / no TLS):
# SMTP_PORT=1025
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_USE_TLS=false
# SMTP_STARTTLS=false
MAIL_FROM=orbit-dev@local
MAIL_TO_CRITICAL=orbit-critical-dev@local
