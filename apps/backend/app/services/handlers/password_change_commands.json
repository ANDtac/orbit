{
  "cisco_ios": [
    "enable secret 0 new_password",
    "line con 0",
    "password 0 new_password",
    "line vty min_vty max_vty",
    "password 0 new_password"
  ],
  "cisco_xe": [
    "enable secret 0 new_password",
    "line con 0",
    "password 0 new_password",
    "line vty min_vty max_vty",
    "password 0 new_password"
  ],
  "cisco_xr": [
    "username root",
    "secret new_password",
    "commit"
  ],
  "cisco_nxos": [
    "username admin password 0 new_password role network-admin"
  ],
  "cisco_asa": [
    "username support password new_password privilege 15",
    "write mem"
  ],
  "cisco_ftd": [
    "configure password",
    "current_enable",
    "new_password",
    "new_password"
  ],
  "juniper_junos": [
    "configure",
    "set system root-authentication plain-text-password",
    "new_password",
    "new_password",
    "set system diag-port-authentication plain-text-password",
    "new_password",
    "new_password",
    "commit"
  ],
  "cimc": [
    "scope user 1",
    "set password",
    "new_password",
    "new_password",
    "commit",
    "exit"
  ],
  "lantronix": [
    "set localuser password sysadmin",
    "new_password",
    "new_password",
    "logout"
  ],
  "wti": [
    "Uses api to change passwords"
  ],
  "apic": [
    "Uses api to change passwords"
  ],
  "ndo": [
    "Uses api to change passwords"
  ],
  "wlc": [
    "enable",
    "current_enable",
    "conf t",
    "enable secret new_password",
    "username admin privilege 15 secret new_password",
    "end",
    "write mem"
  ],
  "f5": [
    "tmsh",
    "modify auth user admin prompt-for-password",
    "new_password",
    "new_password",
    "modify auth password root",
    "new_password",
    "new_password",
    "save sys config"
  ],
  "f5_oshost": [
    "Uses api to change passwords"
  ],
  "gigamon": [
    "fmctl set UI admin password new_password"
  ],
  "expressway": [
    "Uses api to change passwords"
  ],
  "ise": [
    "Uses api to change passwords"
  ]
}
