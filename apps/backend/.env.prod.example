# apps/backend/.env.prod.example
# ------------------------------
# Production environment variables for Orbit backend

APP_ENV=production
FLASK_ENV=production

# Postgres production database
DATABASE_URL=postgresql+psycopg2://orbit_prod:secure_password@db-prod:5432/orbit_prod

# JWT secret (strong, unique, keep private!)
JWT_SECRET_KEY=replace-with-64-char-secret

# SMTP relay (production hardened mail server)
SMTP_HOST=smtp.prod.local
# Uncomment/adjust if your relay requires more configuration:
# SMTP_PORT=465
# SMTP_USERNAME=orbit_prod
# SMTP_PASSWORD=replace-with-strong-secret
# SMTP_USE_TLS=true
# SMTP_STARTTLS=false
MAIL_FROM=orbit@yourorg.com
MAIL_TO_CRITICAL=orbit-critical@yourorg.com
