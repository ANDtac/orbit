# Orbit backend - production environment variables
APP_ENV=production
FLASK_ENV=production

FLASK_DEBUG=0
SECRET_KEY=prod-change-me
JWT_SECRET_KEY=prod-change-me
DATABASE_URL=postgresql+psycopg2://orbit:${ORBIT_DB_PASSWORD}@db:5432/orbit
SQLALCHEMY_DATABASE_URI=${DATABASE_URL}
SQLALCHEMY_TRACK_MODIFICATIONS=False
LOG_LEVEL=WARNING
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=apikey
MAIL_PASSWORD=replace-me
MAIL_DEFAULT_SENDER=orbit@example.com
CORS_ORIGINS=https://orbit.example.com
AUTH_NETMIKO_HOST=
AUTH_NETMIKO_DEVICE_TYPE=
AUTH_NETMIKO_PORT=22
AUTH_NETMIKO_TIMEOUT=10
AUTH_LOGIN_MAX_ATTEMPTS=5
AUTH_LOGIN_WINDOW_SECONDS=900
AUTH_LOGIN_LOCKOUT_SECONDS=900


# Postgres production database
DATABASE_URL=postgresql+psycopg2://orbit_prod:secure_password@db-prod:5432/orbit_prod

# JWT secret (strong, unique, keep private!)
JWT_SECRET_KEY=replace-with-64-char-secret

# SMTP relay (production hardened mail server)
SMTP_HOST=smtp.prod.local
# Uncomment/adjust if your relay requires more configuration:
# SMTP_PORT=465
# SMTP_USERNAME=orbit_prod
# SMTP_PASSWORD=replace-with-strong-secret
# SMTP_USE_TLS=true
# SMTP_STARTTLS=false
MAIL_FROM=orbit@yourorg.com
MAIL_TO_CRITICAL=orbit-critical@yourorg.com
