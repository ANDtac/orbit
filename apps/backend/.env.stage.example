# Orbit backend - staging environment variables
APP_ENV=staging
FLASK_ENV=production

FLASK_DEBUG=0
SECRET_KEY=stage-change-me
JWT_SECRET_KEY=stage-change-me

# Staging database (Postgres)
DATABASE_URL=postgresql+psycopg2://orbit_stage:orbit_stage_pw@db-stage:5432/orbit_stage
SQLALCHEMY_DATABASE_URI=${DATABASE_URL}
SQLALCHEMY_TRACK_MODIFICATIONS=False

# Uncomment to use the shared staging database service from docker-compose
# DATABASE_URL=postgresql+psycopg2://orbit:orbit@db:5432/orbit_stage

LOG_LEVEL=INFO
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=apikey
MAIL_PASSWORD=replace-me
MAIL_DEFAULT_SENDER=orbit-stage@example.com

CORS_ORIGINS=https://staging.orbit.example.com

AUTH_NETMIKO_HOST=
AUTH_NETMIKO_DEVICE_TYPE=
AUTH_NETMIKO_PORT=22
AUTH_NETMIKO_TIMEOUT=10
AUTH_LOGIN_MAX_ATTEMPTS=5
AUTH_LOGIN_WINDOW_SECONDS=900
AUTH_LOGIN_LOCKOUT_SECONDS=900

# SMTP relay (internal staging mail or test relay)
SMTP_HOST=smtp.stage.local
# SMTP_PORT=587
# SMTP_USERNAME=orbit_stage
# SMTP_PASSWORD=changeme
# SMTP_USE_TLS=false
# SMTP_STARTTLS=true
MAIL_FROM=orbit-stage@yourorg.local
MAIL_TO_CRITICAL=orbit-critical-stage@yourorg.local
